{
  "name": "bobble-league-web",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Unicup: a web-based multiplayer Universe Cup played by handless bobbleheads on PlanetBall.",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "start": "tsx server/index.ts",
    "test": "vitest run",
    "betabots": "node scripts/betabots-match.mjs",
    "multiplayer-smoke": "node scripts/multiplayer-smoke.mjs",
    "smoke": "node scripts/stage1-smoke.mjs",
    "render-check": "node scripts/stage2-render-check.mjs",
    "box-check": "node --import tsx scripts/box-control-check.mjs",
    "menu-check": "node scripts/main-menu-check.mjs",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "analyze:original": "node scripts/analyze-original-logs.mjs",
    "compare:original": "tsx scripts/compare-original-feel.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.4",
    "@clerk/react": "^6.12.2",
    "@dimforge/rapier3d-deterministic-compat": "^0.19.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "latest",
    "compression": "latest",
    "cors": "latest",
    "express": "latest",
    "helmet": "latest",
    "nanoid": "latest",
    "react": "latest",
    "react-dom": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest",
    "three": "^0.185.1",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/compression": "latest",
    "@types/express": "latest",
    "@types/jsdom": "^28.0.3",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "jsdom": "latest",
    "playwright": "^1.61.1",
    "typescript-eslint": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
