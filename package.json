{
  "name": "bobble-league-web",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Babble League: web-based multiplayer babble soccer game inspired by Discord party sports games.",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "start": "tsx server/index.ts",
    "test": "vitest run",
    "betabots": "node scripts/betabots-match.mjs",
    "multiplayer-smoke": "node scripts/multiplayer-smoke.mjs",
    "smoke": "node scripts/stage1-smoke.mjs",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "latest",
    "compression": "latest",
    "cors": "latest",
    "express": "latest",
    "helmet": "latest",
    "nanoid": "latest",
    "react": "latest",
    "react-dom": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest",
    "three": "^0.185.1",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/compression": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "jsdom": "latest",
    "playwright": "^1.61.1",
    "typescript-eslint": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
